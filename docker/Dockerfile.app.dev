# Development Docker image — includes dev dependencies, runs with hot-reload
# Usage: docker compose -f docker-compose.dev.yml up --build

FROM python:3.12-slim

WORKDIR /app

# Install dev dependencies
RUN apt-get update && apt-get install -y --no-install-recommends \
    gcc \
    && rm -rf /var/lib/apt/lists/*

COPY requirements-dev.txt .
RUN pip install --no-cache-dir -r requirements-dev.txt

# Copy app source (for non-volume builds; overridden by volume mount in compose)
COPY app/ ./app/
COPY alembic/ ./alembic/
COPY alembic.ini .

RUN mkdir -p /app/data

EXPOSE 8000

# Hot-reload via --reload flag
CMD ["uvicorn", "app.main:app", "--host", "0.0.0.0", "--port", "8000", "--reload"]
