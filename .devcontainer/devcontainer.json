{
  "name": "Python FastAPI App",
  // Pre-built image from .devcontainer/Dockerfile via .github/workflows/devcontainer-image.yml
  // To build locally instead, replace "image" with:
  //   "build": { "dockerfile": "Dockerfile" },
  "image": "ghcr.io/ericbusboom/docker-python-template/devcontainer:latest",

  "features": {
    "ghcr.io/devcontainers/features/docker-in-docker:2": {
      "moby": true,
      "azureDnsAutoDetection": true,
      "installDockerBuildx": true,
      "version": "latest",
      "dockerDashComposeVersion": "v2"
    }
  },

  "postCreateCommand": ".devcontainer/post-create.sh",

  "customizations": {
    "vscode": {
      "extensions": [
        "ms-python.python",
        "ms-python.vscode-pylance",
        "charliermarsh.ruff",
        "tamasfe.even-better-toml",
        "mtxr.sqltools"
      ]
    }
  },

  "forwardPorts": [8000]
}
